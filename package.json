{
  "name": "agent-axon-client",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runloopai/agent-axon-client-ts.git"
  },
  "homepage": "https://github.com/runloopai/agent-axon-client-ts#readme",
  "bugs": {
    "url": "https://github.com/runloopai/agent-axon-client-ts/issues"
  },
  "license": "MIT",
  "workspaces": [
    "sdk",
    "examples/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '@runloop/agent-axon-client' typecheck",
    "build": "bun run --filter '@runloop/agent-axon-client' build",
    "test": "bun run --filter '@runloop/agent-axon-client' test",
    "lint": "bun run --filter '@runloop/agent-axon-client' lint",
    "check": "bun run --filter '@runloop/agent-axon-client' check",
    "clean": "rm -rf sdk/dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
