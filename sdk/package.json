{
  "name": "@runloop/remote-agents-sdk",
  "version": "0.4.3",
  "description": "TypeScript SDK for connecting to Runloop-hosted remote agents using Axons",
  "license": "MIT",
  "author": "Runloop, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runloopai/remote-agents-sdk.git",
    "directory": "sdk"
  },
  "homepage": "https://runloopai.github.io/remote-agents-sdk/",
  "bugs": {
    "url": "https://github.com/runloopai/remote-agents-sdk/issues"
  },
  "keywords": [
    "runloop",
    "remote-agents",
    "axon",
    "acp",
    "claude",
    "agent",
    "sdk"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./acp": {
      "types": "./dist/acp/index.d.ts",
      "import": "./dist/acp/index.js",
      "default": "./dist/acp/index.js"
    },
    "./claude": {
      "types": "./dist/claude/index.d.ts",
      "import": "./dist/claude/index.js",
      "default": "./dist/claude/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "default": "./dist/shared/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__test-utils__"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "typecheck": "tsc --project tsconfig.check.json",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "rm -rf dist && tsc",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --fix ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.90",
    "@runloop/api-client": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "@biomejs/biome": "^2.4.10",
    "@runloop/api-client": "^1.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
