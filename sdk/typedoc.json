{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/acp/index.ts", "src/claude/index.ts", "src/shared/index.ts"],
  "plugin": ["./typedoc-default-category-plugin.mjs"],
  "out": "docs",
  "name": "@runloop/remote-agents-sdk",
  "readme": "README.md",
